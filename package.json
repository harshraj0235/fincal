{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:next": "next dev",
    "build": "npm run generate-sitemaps && node scripts/generate-static-params.cjs && npm run build:next",
    "build:vite": "npm run generate-sitemaps && tsc && vite build",
    "build:next": "node --max-old-space-size=3072 ./node_modules/next/dist/bin/next build",
    "start:next": "next start",
    "preview:cf": "npm run build && npx wrangler pages dev out",
    "deploy:cf": "npm run build && npx wrangler pages deploy out --project-name=moneycal",
    "build:cf:ci": "npm install --legacy-peer-deps && npm run generate-sitemaps && node scripts/generate-static-params.cjs && npm run build:next",
    "upload:cf": "npm run build && npx wrangler pages deploy out --project-name=moneycal",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "build:deploy": "npm install && npm run build",
    "lint": "eslint . --ext ts,tsx --report-unused-directives --max-warnings 0",
    "preview": "vite preview",
    "generate-blogs": "node automated-blog-generator.cjs",
    "generate-crypto": "node crypto-blog-generator.cjs",
    "generate-manual": "node manual-blog-generator.cjs",
    "find-pages-no-default": "node scripts/find-pages-without-default.cjs",
    "find-mismatched-exports": "node scripts/find-mismatched-exports.cjs",
    "generate-sitemaps": "node scripts/build-complete-learn-urls.cjs && node scripts/extract-all-routes-from-code.cjs && node scripts/merge-all-urls.cjs && node scripts/generate-news-sitemap-from-registry.cjs && node scripts/generate-sitemaps-production.cjs",
    "generate-news-sitemap": "node scripts/generate-news-sitemap-from-registry.cjs",
    "fetch-trending-rss": "node scripts/fetch-trending-rss.cjs",
    "deploy": "node deploy.cjs",
    "auto-news": "node scripts/auto-news-generator.cjs",
    "publish-news": "node scripts/auto-news-publisher/main.js",
    "test-news-system": "NODE_ENV=development node scripts/auto-news-publisher/main.js",
    "lhci:autorun": "lhci autorun"
  },
  "dependencies": {
    "@types/react-helmet-async": "^1.0.1",
    "axios": "^1.6.0",
    "chart.js": "^4.5.0",
    "d3": "^7.8.5",
    "firebase": "^11.10.0",
    "framer-motion": "^12.23.12",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.2",
    "lucide-react": "^0.344.0",
    "node-cron": "^3.0.3",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-icons": "^5.5.0",
    "react-router-dom": "^6.30.1",
    "recharts": "^2.15.4",
    "tailwind-merge": "^3.3.1",
    "next": "^15.1.0",
    "web-vitals": "^3.5.2",
    "xlsx": "^0.18.5",
    "xml2js": "^0.6.2"
  },
  "overrides": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^24.0.3",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "terser": "^5.29.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.19",
    "vite-plugin-compression": "^0.5.1",
    "eslint-config-next": "^15.1.0",
    "wrangler": "^3.99.0"
  }
}

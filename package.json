{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npx tsx scripts/generateDiscoverMetadata.ts && node scripts/generate-discover-content.cjs && node scripts/auto-freshness-updater.cjs && npm run generate-sitemaps && node scripts/inject-faq-schema.cjs && npx tsc && vite build && npm run prerender && node scripts/indexnow-ping.cjs",
    "build:deploy": "npm install && npm run build",
    "prerender": "node scripts/prerender.cjs",
    "lint": "eslint . --max-warnings 0",
    "preview": "vite preview",
    "generate-blogs": "node automated-blog-generator.cjs",
    "generate-crypto": "node crypto-blog-generator.cjs",
    "generate-manual": "node manual-blog-generator.cjs",
    "generate-sitemaps": "node scripts/build-complete-learn-urls.cjs && node scripts/extract-all-routes-from-code.cjs && node scripts/merge-all-urls.cjs && node scripts/generate-sitemaps-production.cjs",
    "deploy": "node deploy.cjs",
    "auto-news": "node scripts/auto-news-generator.cjs",
    "publish-news": "node scripts/auto-news-publisher/main.js",
    "test-news-system": "NODE_ENV=development node scripts/auto-news-publisher/main.js",
    "lhci:autorun": "lhci autorun"
  },
  "dependencies": {
    "@types/react-helmet-async": "^1.0.1",
    "axios": "^1.6.0",
    "chart.js": "^4.5.0",
    "d3": "^7.8.5",
    "firebase": "^11.10.0",
    "framer-motion": "^12.23.12",
    "fuse.js": "^7.5.0",
    "googleapis": "^171.4.0",
    "html2canvas": "^1.4.1",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^4.0.0",
    "jspdf": "^3.0.2",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.344.0",
    "node-cron": "^3.0.3",
    "pdfjs-dist": "^5.4.624",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^17.0.8",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.1",
    "recharts": "^2.15.4",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1",
    "web-vitals": "^3.5.2",
    "xlsx": "^0.18.5",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^24.0.3",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/react-router-dom": "^5.3.3",
    "@vitalets/google-translate-api": "^9.2.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "esbuild": "^0.28.1",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "react-snap": "^1.23.0",
    "tailwindcss": "^3.4.1",
    "terser": "^5.29.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.19",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-image-optimizer": "^2.0.3"
  }
}

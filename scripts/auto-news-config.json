{
  "service": {
    "name": "MoneyCalAutoNewsGenerator",
    "description": "Automated Hindi news blog generator for MoneyCal India",
    "enabled": true,
    "autoStart": true
  },
  "blogGeneration": {
    "postsPerCycle": 10,
    "intervalHours": 36,
    "wordCountTarget": 1200,
    "categories": ["finance", "technology", "business", "stock market", "cryptocurrency", "startup", "investment", "banking", "insurance", "real estate"],
    "cities": [
      "Mumbai", "Delhi", "Bangalore", "Hyderabad", "Chennai", "Kolkata", "Pune", "Ahmedabad", "Jaipur", "Surat",
      "Lucknow", "Kanpur", "Nagpur", "Indore", "Thane", "Bhopal", "Visakhapatnam", "Pimpri-Chinchwad", "Patna", "Vadodara",
      "Ghaziabad", "Ludhiana", "Agra", "Nashik", "Faridabad", "Meerut", "Rajkot", "Kalyan-Dombivali", "Vasai-Virar", "Varanasi"
    ]
  },
  "gitSync": {
    "enabled": true,
    "autoSyncIntervalHours": 12,
    "repository": "https://github.com/harshraj0235/fincal",
    "branch": "main",
    "autoCommit": true,
    "autoPush": true,
    "autoPull": true
  },
  "contentUpdate": {
    "updateExistingBlogDates": true,
    "updateIntervalHours": 24,
    "keepContentFresh": true
  },
  "logging": {
    "level": "info",
    "saveToFile": true,
    "logFile": "auto-news-generator.log",
    "maxLogSize": "10MB",
    "maxLogFiles": 5
  },
  "notifications": {
    "email": false,
    "webhook": false,
    "console": true
  },
  "schedule": {
    "timezone": "Asia/Kolkata",
    "businessHoursOnly": false,
    "pauseOnWeekends": false
  }
}

{
  "service": {
    "name": "MoneyCalMasterScheduler",
    "description": "Automated content generation and GitHub sync service for MoneyCal",
    "enabled": true,
    "autoStart": true,
    "version": "1.0.0"
  },
  "scripts": [
    {
      "name": "Auto News Generator",
      "file": "auto-news-generator.cjs",
      "enabled": true,
      "intervalHours": 36,
      "description": "Generates Hindi news blog posts automatically"
    },
    {
      "name": "Government Jobs Generator",
      "file": "auto-government-jobs-generator.cjs",
      "enabled": true,
      "intervalHours": 36,
      "description": "Generates government job related content"
    },
    {
      "name": "Scheme Job Generator",
      "file": "auto-scheme-job-generator.cjs",
      "enabled": true,
      "intervalHours": 36,
      "description": "Generates government scheme and job content"
    },
    {
      "name": "Blog Generator",
      "file": "generate-blogs.cjs",
      "enabled": true,
      "intervalHours": 36,
      "description": "Generates general blog content"
    }
  ],
  "gitSync": {
    "enabled": true,
    "repository": "https://github.com/harshraj0235/fincal",
    "branch": "main",
    "autoSyncIntervalHours": 12,
    "commitMessage": "Auto-sync: Updated content and data files",
    "pullBeforePush": true,
    "autoCommit": true,
    "autoPush": true,
    "conflictResolution": "auto"
  },
  "schedule": {
    "timezone": "Asia/Kolkata",
    "runEveryHours": 36,
    "startDelayMinutes": 5,
    "businessHoursOnly": false,
    "pauseOnWeekends": false,
    "randomDelayBetweenScripts": {
      "enabled": true,
      "minSeconds": 30,
      "maxSeconds": 300
    }
  },
  "logging": {
    "level": "info",
    "saveToFile": true,
    "logFile": "master-scheduler.log",
    "maxLogSize": "10MB",
    "maxLogFiles": 5,
    "consoleOutput": true,
    "timestampFormat": "ISO"
  },
  "notifications": {
    "email": {
      "enabled": false,
      "smtp": {
        "host": "",
        "port": 587,
        "secure": false,
        "user": "",
        "pass": ""
      },
      "recipients": []
    },
    "webhook": {
      "enabled": false,
      "url": "",
      "method": "POST"
    },
    "console": true
  },
  "monitoring": {
    "healthCheck": {
      "enabled": true,
      "intervalMinutes": 60,
      "maxFailures": 3
    },
    "performance": {
      "trackMemoryUsage": true,
      "trackCpuUsage": true,
      "maxMemoryMB": 512,
      "maxCpuPercent": 80
    }
  },
  "backup": {
    "enabled": true,
    "backupDirectory": "backups",
    "backupIntervalHours": 24,
    "maxBackups": 7,
    "includeLogs": true,
    "includeConfig": true
  },
  "security": {
    "validateScripts": true,
    "checkFileIntegrity": true,
    "maxExecutionTimeMinutes": 30,
    "allowedFileExtensions": [".cjs", ".js", ".json"]
  }
}

# Headers for proper MIME types and caching

# JavaScript files
/assets/*.js
  Content-Type: application/javascript
  Cache-Control: public, max-age=31536000, immutable

# CSS files
/assets/*.css
  Content-Type: text/css
  Cache-Control: public, max-age=31536000, immutable

# Font files
/fonts/*.woff2
  Content-Type: font/woff2
  Cache-Control: public, max-age=31536000, immutable

/fonts/*.woff
  Content-Type: font/woff
  Cache-Control: public, max-age=31536000, immutable

# Image files
/images/*.jpg
  Content-Type: image/jpeg
  Cache-Control: public, max-age=31536000, immutable

/images/*.jpeg
  Content-Type: image/jpeg
  Cache-Control: public, max-age=31536000, immutable

/images/*.png
  Content-Type: image/png
  Cache-Control: public, max-age=31536000, immutable

/images/*.svg
  Content-Type: image/svg+xml
  Cache-Control: public, max-age=31536000, immutable

/images/*.webp
  Content-Type: image/webp
  Cache-Control: public, max-age=31536000, immutable

# Manifest and icons
/*.png
  Content-Type: image/png

# HTML files - SEO optimized
/*.html
  Content-Type: text/html; charset=utf-8
  Cache-Control: public, max-age=0, must-revalidate
  X-Robots-Tag: index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1

# Sitemap files
/sitemap*.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600
  X-Robots-Tag: noindex

# All other files
/*
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: frame-ancestors 'self' https://*.google.com https://*.googleadservices.com https://*.doubleclick.net https://*.googlesyndication.com

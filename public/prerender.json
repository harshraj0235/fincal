{
  "prerendercloud": {
    "enable": true,
    "host": "moneycal.in",
    "protocol": "https"
  },
  "routes": [
    "/",
    "/calculators/*",
    "/blog/*",
    "/learn/*",
    "/tools/*",
    "/government-schemes/*",
    "/finance-tools/*"
  ],
  "userAgents": [
    "googlebot",
    "bingbot",
    "slurp",
    "duckduckbot"
  ],
  "cacheMaxAge": 86400,
  "followRedirects": true,
  "removeScriptTags": false,
  "removeStyleTags": false
}

